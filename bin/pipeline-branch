#!/usr/bin/env bash
# Branch and worktree management for pipeline.
# Usage: pipeline-branch <action> [options]
# Actions: staging-init, create, worktree-create, worktree-remove, exists, naming
# Exit: 0=success, 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command git

action="${1:?missing action}"
shift

case "$action" in
  staging-init)
    if git ls-remote --heads origin staging 2>/dev/null | grep -q staging; then
      git fetch origin staging &>/dev/null
      git checkout staging &>/dev/null
      git pull origin staging &>/dev/null
      json_output staging_branch "staging" base "existing" created "false"
    else
      if git ls-remote --heads origin develop 2>/dev/null | grep -q develop; then
        base="develop"
        git fetch origin develop &>/dev/null
        git checkout -b staging "origin/develop" &>/dev/null
      else
        base="main"
        git fetch origin main &>/dev/null
        git checkout -b staging "origin/main" &>/dev/null
      fi
      git push -u origin staging &>/dev/null
      json_output staging_branch "staging" base "$base" created "true"
    fi
    ;;

  create)
    name="${1:?missing branch name}"
    shift
    base="staging"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --base) base="$2"; shift 2 ;;
        *) log_error "unknown flag: $1"; exit 1 ;;
      esac
    done
    git checkout -b "$name" "$base" &>/dev/null
    json_output branch "$name" base "$base" action "created"
    ;;

  worktree-create)
    name="${1:?missing branch name}"
    path="${2:?missing worktree path}"
    base="${3:-staging}"
    git worktree add -b "$name" "$path" "$base" &>/dev/null
    json_output branch "$name" path "$path" base "$base" action "created"
    ;;

  worktree-remove)
    path="${1:?missing worktree path}"
    git worktree remove "$path" &>/dev/null || {
      log_warn "force-removing worktree at $path"
      git worktree remove --force "$path" &>/dev/null
    }
    json_output path "$path" action "removed"
    ;;

  exists)
    name="${1:?missing branch name}"
    if git show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      exit 0
    elif git ls-remote --heads origin "$name" 2>/dev/null | grep -q "$name"; then
      exit 0
    else
      exit 1
    fi
    ;;

  naming)
    task_id="${1:?missing task-id}"
    issue="${2:?missing issue number}"
    slug=$(slugify "$task_id")
    printf 'dark-factory/%s/%s' "$issue" "$slug"
    ;;

  *)
    log_error "unknown action: $action"
    echo "Usage: pipeline-branch <staging-init|create|worktree-create|worktree-remove|exists|naming> [options]" >&2
    exit 1
    ;;
esac

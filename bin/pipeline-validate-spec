#!/usr/bin/env bash
# Validate spec generation output (spec.md + tasks.json).
# Usage: pipeline-validate-spec <spec-dir>
# Exit: 0=valid, 1=invalid

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

spec_dir="${1:?missing spec directory}"

errors=()

# Check spec.md
spec_file="$spec_dir/spec.md"
if [[ ! -f "$spec_file" ]]; then
  errors+=("spec.md not found in $spec_dir")
elif [[ ! -s "$spec_file" ]]; then
  errors+=("spec.md is empty")
fi

# Check tasks.json
tasks_file="$spec_dir/tasks.json"
if [[ ! -f "$tasks_file" ]]; then
  errors+=("tasks.json not found in $spec_dir")
else
  # Validate JSON
  if ! jq empty "$tasks_file" 2>/dev/null; then
    errors+=("tasks.json is not valid JSON")
  else
    # Must be array
    is_array=$(jq 'type == "array"' "$tasks_file")
    if [[ "$is_array" != "true" ]]; then
      errors+=("tasks.json must be a JSON array")
    else
      task_count=$(jq 'length' "$tasks_file")
      if [[ "$task_count" -lt 1 ]]; then
        errors+=("tasks.json must contain at least 1 task")
      else
        # Validate each task
        required_fields=("task_id" "title" "description" "files" "acceptance_criteria" "tests_to_write" "depends_on")
        for field in "${required_fields[@]}"; do
          missing=$(jq --arg f "$field" '[to_entries[] | select(.value[$f] == null) | .key] | length' "$tasks_file")
          if [[ "$missing" -gt 0 ]]; then
            indices=$(jq -r --arg f "$field" '[to_entries[] | select(.value[$f] == null) | .key | tostring] | join(", ")' "$tasks_file")
            errors+=("missing field '$field' in task(s) at index: $indices")
          fi
        done

        # Validate files array length <= 3
        over_limit=$(jq '[to_entries[] | select((.value.files // []) | length > 3) | .key] | length' "$tasks_file")
        if [[ "$over_limit" -gt 0 ]]; then
          indices=$(jq -r '[to_entries[] | select((.value.files // []) | length > 3) | .key | tostring] | join(", ")' "$tasks_file")
          errors+=("files array exceeds 3 in task(s) at index: $indices")
        fi

        # Validate task_id uniqueness
        unique_ids=$(jq '[.[].task_id] | unique | length' "$tasks_file")
        total_ids=$(jq '[.[].task_id] | length' "$tasks_file")
        if [[ "$unique_ids" != "$total_ids" ]]; then
          errors+=("duplicate task_id values found")
        fi

        # Validate depends_on references exist
        dangling=$(jq '
          [.[].task_id] as $all_ids |
          [.[] | (.depends_on // [])[] | select(. as $d | $all_ids | index($d) | not)] | unique
        ' "$tasks_file" 2>/dev/null)
        dangling_count=$(printf '%s' "$dangling" | jq 'length' 2>/dev/null || echo 0)
        if [[ "$dangling_count" -gt 0 ]]; then
          dangling_list=$(printf '%s' "$dangling" | jq -r 'join(", ")')
          errors+=("dangling depends_on references: $dangling_list")
        fi
      fi
    fi
  fi
fi

# Build output
error_count=${#errors[@]}
if [[ $error_count -eq 0 ]]; then
  jq -n \
    --argjson valid true \
    --argjson task_count "${task_count:-0}" \
    '{valid: $valid, errors: [], task_count: $task_count}'
else
  errors_json=$(printf '%s\n' "${errors[@]}" | jq -R -s 'split("\n") | map(select(length > 0))')
  jq -n \
    --argjson valid false \
    --argjson errors "$errors_json" \
    --argjson task_count "${task_count:-0}" \
    '{valid: $valid, errors: $errors, task_count: $task_count}'
  exit 1
fi
